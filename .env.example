# WordPress REST API base URL — required for pnpm build and pnpm dev
WP_API_BASE=

# WordPress theme deploy via rsync over SSH (pre-push hook, main branch only)
# Leave blank to skip theme deployment on push.
WP_SSH_USER=
WP_SSH_HOST=
WP_SSH_PATH=
WP_SSH_PORT=22
WP_SSH_KEY=/absolute/path/to/.ssh/id_ed25519
