---
import logo from "../assets/img/logo.svg";
import Navigation from "./Navigation.astro";
---

<header
    id="masthead"
    class="relative flex min-h-screen items-center justify-center bg-cover bg-center text-center text-white"
    style="background-image: url(/img/dancefloor.png);"
>
    <div class="absolute inset-0 bg-black/40" aria-hidden="true"></div>

    <div class="relative z-10 container mx-auto px-4 lg:px-5">
        <h1 class="sr-only">Career Tomboy</h1>

        <div class="mx-auto max-w-xl">
            <img
                src={logo.src}
                alt="Career Tomboy logo"
                class="mx-auto max-w-xs sm:max-w-sm"
            />

            <p class="text-white-75 mt-6 text-lg">
                Alternative rock hits and deep cuts from the 1990s and 2000s... and
                more.
            </p>

            <!-- Navigation positioned below tagline, becomes sticky on scroll -->
            <div id="navWrapper" class="mt-8">
                <Navigation />
            </div>
        </div>
    </div>
</header>

<script>
    const nav = document.getElementById('mainNav');
    const navWrapper = document.getElementById('navWrapper');

    if (nav && navWrapper) {
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        // Nav wrapper is visible - nav in normal flow below tagline
                        nav.classList.remove('fixed', 'top-3', 'left-1/2', '-translate-x-1/2');
                    } else {
                        // Nav wrapper has scrolled out of view - fix nav at top
                        nav.classList.add('fixed', 'top-3', 'left-1/2', '-translate-x-1/2');
                    }
                });
            },
            {
                // Trigger when nav wrapper reaches the top of the viewport
                // The negative top margin accounts for the fixed position offset (top-3 = 0.75rem = 12px)
                threshold: 0,
                rootMargin: '-12px 0px 0px 0px',
            }
        );

        observer.observe(navWrapper);
    }
</script>
