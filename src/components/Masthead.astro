---
import logo from "../assets/img/logo.svg";
import Navigation from "./Navigation.astro";
---

<header
    id="masthead"
    class="relative flex min-h-screen items-center justify-center bg-cover bg-center text-center text-white"
    style="background-image: url(/img/dancefloor.png);"
>
    <div class="absolute inset-0 bg-black/40" aria-hidden="true"></div>

    <div class="relative z-10 container mx-auto px-4 lg:px-5">
        <h1 class="sr-only">Career Tomboy</h1>

        <div class="mx-auto max-w-xl">
            <img
                src={logo.src}
                alt="Career Tomboy logo"
                class="mx-auto max-w-xs sm:max-w-sm"
            />

            <p class="text-white-75 mt-6 text-lg">
                Alternative rock hits and deep cuts from the 1990s and 2000s... and
                more.
            </p>
        </div>
    </div>

    <!-- Navigation positioned at bottom of masthead, becomes sticky on scroll -->
    <Navigation />
</header>

<script>
    const masthead = document.getElementById('masthead');
    const nav = document.getElementById('mainNav');

    if (masthead && nav) {
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        // Masthead is visible - position nav at bottom of masthead
                        nav.classList.remove('fixed', 'top-3');
                        nav.classList.add('absolute', 'bottom-8');
                    } else {
                        // Masthead is out of view - fix nav at top
                        nav.classList.remove('absolute', 'bottom-8');
                        nav.classList.add('fixed', 'top-3');
                    }
                });
            },
            {
                // Trigger when masthead is about to leave the viewport
                threshold: 0,
                rootMargin: '-60px 0px 0px 0px',
            }
        );

        observer.observe(masthead);
    }
</script>
