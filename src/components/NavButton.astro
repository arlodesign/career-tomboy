---
interface Props {
    label: string;
    href: string;
    current?: boolean;
}

const { label, href, current = false } = Astro.props as Props;
---

<li>
    <a
        href={href}
        class="px-3 py-2 text-ct-white inline-block relative font-bold focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ct-white focus-visible:ring-offset-2 focus-visible:ring-offset-ct-black focus-visible:rounded"
        aria-current={current ? "page" : undefined}
    >
        <span
            class="relative inline-block before:absolute before:-inset-2 before:block before:skew-y-1 hover:before:-skew-y-2 before:bg-ct-black"
            ><span class="relative">{label}</span></span
        >
    </a>
</li>
