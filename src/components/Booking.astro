---
import Section from "./Section.astro";
import songs from "../data/songs.json";

function normalizeArtistForSort(artist?: string | null): string {
    const raw = (artist ?? "").trim();
    const lower = raw.toLowerCase();
    if (lower.startsWith("the ")) {
        // Ignore leading article "The" when sorting (e.g., "The Cure" → "Cure")
        return lower.slice(4);
    }
    return lower;
}

const sortedSongs = [...songs].sort((a, b) => {
    const artistA = normalizeArtistForSort(a.artist);
    const artistB = normalizeArtistForSort(b.artist);
    if (artistA !== artistB) return artistA.localeCompare(artistB);
    const titleA = (a.title ?? "").toLowerCase();
    const titleB = (b.title ?? "").toLowerCase();
    return titleA.localeCompare(titleB);
});
---

<Section id="booking" headline="Book Us" color="lime">
    <div class="mx-auto max-w-3xl">
        <h3 class="mt-4 font-heading text-xl italic pb-4">
            Career Tomboy plays “alternative classics and deep cuts"
        </h3>
        <p class="mb-4">That means we play…</p>
        <ul class="mb-4 pl-2 flex flex-col gap-2">
            <li>…classics from the alternative era (1990s, 2000s)</li>
            <li>
                …alternative picks from the classic era (1960s, 1970s, 1980s)
            </li>
            <li>
                …deep cuts from any era, including current bands you aren’t
                listening to… <em>yet</em>
            </li>
        </ul>
        <p class="mb-4">
            Our sets are ecclectic, meaning everyone will hear something they
            love and something they will love as soon as they hear it for the
            first time.
        </p>
        <details class="my-8 border-2 border-black open:bg-white">
            <summary
                class="font-bold text-center px-3 py-2 text-sm font-medium text-black transition-colors hover:bg-black hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 cursor-pointer"
                >Here’s every song we've ever played…</summary
            >
            <div class="overflow-x-auto mt-4 p-4">
                <dl
                    class="text-sm grid grid-cols-2 gap-3"
                    aria-label="Songs We've Played"
                >
                    {
                        sortedSongs.map((song) => (
                            <>
                                <dt class="font-bold text-right">
                                    {song.title}
                                </dt>
                                <dd class="">{song.artist}</dd>
                            </>
                        ))
                    }
                </dl>
            </div>
        </details>

        <h3 class="mt-4 font-heading text-xl italic pb-4">
            Career Tomboy is not your typical cover band
        </h3>
        <p class="mb-4">
            When you need something a little different for your next live-music
            night at the bar, outdoor festival, second or third wedding,
            corporate event, 45th+ birthday, or very unconventional bris,
            contact us!
        </p><p class="mb-4">
            <strong>Fill out the form below.</strong> We take requests! We bring our
            own gear! We work for beer! (But we also take Venmo and Zelle.)
        </p>
    </div>
    <iframe
        class="mx-auto w-full max-w-4xl h-screen"
        src="https://docs.google.com/forms/d/e/1FAIpQLSdxeGcmSU8EvM2Vf48TR-MINphuPrhIaSk-to8nH_JfADP9KQ/viewform?embedded=true"
        frameborder="0"
        marginheight="0"
        marginwidth="0">Loading…</iframe
    >
</Section>

<script>
    const modal = document.getElementById("setlist-modal") as HTMLDialogElement;
    const openBtn = document.getElementById("open-setlist");
    const closeBtn = document.getElementById("close-setlist");

    openBtn?.addEventListener("click", () => {
        modal.showModal();
        closeBtn?.focus();
    });

    const closeModal = () => {
        modal.close();
        openBtn?.focus();
    };

    closeBtn?.addEventListener("click", closeModal);
    modal.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
    });
</script>
