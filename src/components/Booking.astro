---
import Section from './Section.astro';
import { fetchSongs, fetchBookingPage } from '../lib/wordpress';
import type { Song } from '../lib/wordpress';

const [songs, booking] = await Promise.all([fetchSongs(), fetchBookingPage()]);

function normalizeArtistForSort(artist?: string | null): string {
    const raw = (artist ?? '').trim();
    const lower = raw.toLowerCase();
    if (lower.startsWith('the ')) {
        // Ignore leading article "The" when sorting (e.g., "The Cure" → "Cure")
        return lower.slice(4);
    }
    return lower;
}

const sortedSongs = [...songs].sort((a: Song, b: Song) => {
    const artistA = normalizeArtistForSort(a.artist);
    const artistB = normalizeArtistForSort(b.artist);
    if (artistA !== artistB) return artistA.localeCompare(artistB);
    const titleA = (a.title ?? '').toLowerCase();
    const titleB = (b.title ?? '').toLowerCase();
    return titleA.localeCompare(titleB);
});
---

<Section id="booking" headline="Book Us" color="lime">
    <div class="mx-auto max-w-3xl text-sm">
        <div class="ct-booking-content" set:html={booking.contentBefore} />

        <details class="my-8 border-2 border-black open:bg-white">
            <summary
                class="font-bold text-center px-3 py-2 text-sm font-medium text-black transition-colors hover:bg-black hover:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 cursor-pointer"
                >Here's every song we've ever played…</summary
            >
            <div class="overflow-x-auto mt-4 p-4">
                <dl class="text-sm grid grid-cols-2 gap-3" aria-label="Songs We've Played">
                    {
                        sortedSongs.map((song) => (
                            <>
                                <dt class="font-bold text-right">{song.title}</dt>
                                <dd class="">{song.artist}</dd>
                            </>
                        ))
                    }
                </dl>
            </div>
        </details>

        <div class="ct-booking-content" set:html={booking.contentAfter} />
    </div>
    {
        booking.formUrl && (
            <iframe
                class="mx-auto w-full max-w-4xl h-screen"
                src={booking.formUrl}
                frameborder="0"
                marginheight="0"
                marginwidth="0"
            >
                Loading…
            </iframe>
        )
    }
</Section>

<style>
    /* Style WordPress-rendered prose. Mirrors the original Tailwind utility
       classes that were previously applied directly to the markup. */
    .ct-booking-content :global(h3) {
        margin-top: 1rem;
        padding-bottom: 1rem;
        font-family: var(--font-heading);
        font-size: 1.25rem;
        line-height: 1.75rem;
        font-style: italic;
    }
    .ct-booking-content :global(p) {
        margin-bottom: 1rem;
    }
    .ct-booking-content :global(ul) {
        margin-bottom: 1rem;
        padding-left: 0.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .ct-booking-content :global(li::before) {
        content: '…';
    }
</style>

<script>
    const songsDetails = document.querySelector('#booking details') as HTMLDetailsElement | null;

    songsDetails?.addEventListener('toggle', () => {
        const fn = (window as Window & { updatePatternOffsets?: () => void }).updatePatternOffsets;
        if (typeof fn === 'function') fn();
    });
</script>
