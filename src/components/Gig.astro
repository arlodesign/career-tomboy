---
import type { Gig as GigType } from '../lib/types';
import { generateMapsUrl } from '../lib/gigs';
import { randomSkewClass } from '../lib/variants';
import ActionLink from './ActionLink.astro';

interface Props {
    gig: GigType;
}

const { gig } = Astro.props as Props;

const dateObj = new Date(gig.date);
const formattedDate = dateObj.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
});

const formattedTime = gig.date.includes('T')
    ? dateObj.toLocaleTimeString('en-US', {
          hour: 'numeric',
          minute: '2-digit',
      })
    : null;

const isPrivate = gig.isPrivate;
const mapUrl = !isPrivate && gig.address ? generateMapsUrl(gig.address) : null;
const skewClass = randomSkewClass();
---

<article
    class="group p-4 text-left text-white md:text-base relative"
    data-gig-id={gig.id}
    data-private={isPrivate ? 'true' : undefined}
>
    <span
        class={`relative block before:absolute before:-inset-4 before:block before:bg-black ${skewClass}`}
    >
        <h3 class="relative font-heading text-xl italic text-white">
            <time datetime={gig.date}>
                {formattedDate}
                {formattedTime && <span class="font-normal"> - {formattedTime}</span>}
            </time>
        </h3>
        <div
            class="relative mt-1 flex flex-col gap-2 md:flex-row md:items-start md:justify-between"
        >
            <div class="space-y-1">
                <div class="flex items-center gap-2">
                    <p class="font-medium text-white">{gig.venue}</p>
                    {
                        isPrivate && (
                            <span
                                class="inline-block rounded bg-primary/10 px-2 py-0.5 text-xs font-medium text-white"
                                aria-label="Private event - venue details not disclosed"
                            >
                                Private Event
                            </span>
                        )
                    }
                </div>
                {!isPrivate && gig.address && <p class="text-sm text-white">{gig.address}</p>}
                {
                    gig.supporting && !isPrivate && (
                        <p class="text-sm text-white">With {gig.supporting}</p>
                    )
                }
                {gig.notes && !isPrivate && <p class="text-sm text-white">{gig.notes}</p>}
            </div>
            {
                !isPrivate && (mapUrl || gig.ticketUrl) && (
                    <div class="mt-3 flex flex-wrap gap-2 md:mt-0 md:justify-end">
                        {mapUrl && (
                            <ActionLink
                                href={mapUrl}
                                label="Map"
                                ariaLabel={`View map for ${gig.venue}`}
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    fill="none"
                                    viewBox="0 0 16 16"
                                    id="Map-Search--Streamline-Sharp-Remix"
                                    height="16"
                                    width="16"
                                    slot="icon"
                                    aria-hidden
                                >
                                    <path
                                        fill="currentColor"
                                        fill-rule="evenodd"
                                        d="M15.240133333333333 1.2V0.15999999999999998l-1.0146666666666666 0.22826666666666665 -4.254733333333333 0.9573333333333333L5.715999999999999 0.38826666666666665 5.531 0.3466666666666667l-0.18473333333333333 0.042666666666666665L0.9088666666666666 1.4133333333333333l-0.6449333333333334 0.1488v13.990066666666666l1.0146666666666666 -0.22833333333333333L5.533333333333333 14.366533333333333l2.5042 0.5634666666666666c-0.6549333333333334 -0.5326 -1.1674666666666667 -1.2334666666666667 -1.4717333333333331 -2.0368l-0.20046666666666668 -0.04513333333333333V2.2399999999999998l2.7733333333333334 0.624v3.9008666666666665c0.5139333333333334 -0.22606666666666667 1.0748666666666666 -0.3651333333333333 1.6640666666666668 -0.3985333333333333V2.8640666666666665l2.7733999999999996 -0.6240666666666667v4.813333333333333c0.6843333333333332 0.4144 1.2574666666666667 0.9940666666666667 1.664 1.6836666666666666V1.2ZM4.7013333333333325 2.2458666666666662l-2.7733999999999996 0.6399999999999999v10.586266666666667l2.7733999999999996 -0.6240666666666667V2.2458666666666662Zm6.378733333333333 7.107866666666666c-1.0109333333333332 0 -1.8304 0.8194666666666667 -1.8304 1.8304s0.8194666666666667 1.8304 1.8304 1.8304 1.8304 -0.8194666666666667 1.8304 -1.8304 -0.8194666666666667 -1.8304 -1.8304 -1.8304Zm-3.4944666666666664 1.8304c0 -1.929933333333333 1.5645333333333333 -3.4944666666666664 3.4944666666666664 -3.4944666666666664s3.4944666666666664 1.5645333333333333 3.4944666666666664 3.4944666666666664c0 0.6559333333333333 -0.1808 1.2698 -0.4951333333333333 1.7942l1.6566666666666665 1.6567999999999998 -1.2048666666666665 1.2048666666666665 -1.6567333333333334 -1.6566666666666665c-0.5244666666666666 0.31446666666666667 -1.1382666666666665 0.49526666666666663 -1.7944 0.49526666666666663 -1.929933333333333 0 -3.4944666666666664 -1.5645333333333333 -3.4944666666666664 -3.4944666666666664Z"
                                        clip-rule="evenodd"
                                        stroke-width="0.6667"
                                    />
                                </svg>
                            </ActionLink>
                        )}
                        {gig.ticketUrl && (
                            <ActionLink
                                href={gig.ticketUrl}
                                label="Tickets"
                                ariaLabel={`Get tickets for ${gig.venue}`}
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    fill="none"
                                    viewBox="0 0 16 16"
                                    id="Map-Search--Streamline-Sharp-Remix"
                                    height="16"
                                    width="16"
                                    slot="icon"
                                    aria-hidden
                                >
                                    <path
                                        fill="currentColor"
                                        fill-rule="evenodd"
                                        d="m7.0024 0.22290066666666666 0.8049333333333333 0.21568199999999998 2.0928 0.5607773333333332 0.8049333333333333 0.21567999999999998 -0.21566666666666667 0.80494 -0.1294 0.48295999999999994c-0.09526666666666667 0.35564666666666667 0.11573333333333333 0.7212000000000001 0.47139999999999993 0.8165 0.35566666666666663 0.09529333333333334 0.7212000000000001 -0.11575999999999999 0.8165333333333333 -0.47140666666666664l0.1294 -0.48295999999999994 0.21566666666666667 -0.80494 0.8049333333333333 0.21567999999999998 2.0928666666666667 0.5607733333333333 0.8049333333333333 0.21568666666666664 -0.21573333333333333 0.8049333333333333 -2.9332666666666665 10.947193333333333 -0.21566666666666667 0.8049333333333333 -0.8049333333333333 -0.21573333333333333 -2.2821333333333333 -0.6114666666666666 -5.574953333333333 1.4937999999999998L0.30440266666666665 3.2188866666666667 4.00712 2.2267466666666667l0.3450933333333333 1.2879066666666665c0.09529333333333334 0.35564 0.4608466666666667 0.5666933333333333 0.8164933333333333 0.47139999999999993 0.35564666666666667 -0.09529333333333334 0.5667 -0.46085333333333334 0.47140666666666664 -0.8164933333333333l-0.3450933333333333 -1.2879 1.36058 -0.3645733333333333 0.13106666666666666 -0.48924666666666666 0.21573333333333333 -0.8049393333333332ZM12.556 7.830266666666667l-0.8492666666666666 3.1694666666666667 0 -0.00006666666666666667 -0.5542 2.0682666666666663 -5.473533333333333 -1.4666 1.4034666666666666 -5.237819999999999 0.9658666666666667 0.25881333333333334 0.4314 -1.60988 -0.9659333333333333 -0.25880666666666663 0.6670666666666666 -2.4894999999999996 0.5058 0.13552666666666666c-0.008533333333333334 0.07088 -0.013733333333333334 0.14159333333333332 -0.015733333333333332 0.21195999999999998 -0.0012666666666666666 0.0469 -0.0012 0.09364 0.0003333333333333333 0.14018 0.03233333333333333 1.0007533333333334 0.7115999999999999 1.9049533333333333 1.7288 2.1775066666666665 1.1354 0.30423999999999995 2.299733333333333 -0.28368 2.7485999999999997 -1.3340533333333333l0.5058 0.13551999999999997 -0.6670666666666666 2.48958 -0.966 -0.25882666666666665 -0.43133333333333335 1.6098666666666666 0.9659333333333333 0.25886666666666663Zm-1.9327999999999999 -0.5180666666666667 -1.6098666666666666 -0.4314 0.43133333333333335 -1.6098599999999998 1.6098666666666666 0.4313666666666667 -0.43133333333333335 1.6098933333333332Z"
                                        clip-rule="evenodd"
                                        stroke-width="0.6667"
                                    />
                                </svg>
                            </ActionLink>
                        )}
                    </div>
                )
            }
        </div>
    </span>
</article>
