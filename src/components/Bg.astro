---
interface Props {
    /**
     * Name of the CSS variable to use for the pattern color, e.g. "--color-ct-lime".
     * The component will set `--section-color: var(<colorVar>)` on the root element.
     */
    colorVar?: string;

    /** Additional CSS classes to apply to the background container. */
    class?: string;
}

const { colorVar = '--color-ct-lime', class: className = '' } = Astro.props as Props;

const style = `--section-color: var(${colorVar});`;
---

<div class={`ct-pattern-bg ${className}`} style={style} aria-hidden="true" data-pattern-section>
</div>
