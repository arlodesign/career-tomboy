---
interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "Chicago's favorite 90s/2000s alternative cover band",
} = Astro.props as Props;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<title>{title}</title>

<!-- Fonts: Input Serif from Type Network -->
<link
    href="//fastly-cloud.typenetwork.com/projects/8874/fontface.css?6956d921"
    rel="stylesheet"
    type="text/css"
/>

<!-- Favicon (basic) -->
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
