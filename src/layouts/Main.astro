---
import "../styles/global.css";
import Head from "../components/Head.astro";

interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "Chicago's favorite 90s/2000s alternative cover band",
} = Astro.props as Props;
---

<!doctype html>
<html lang="en">
    <head>
        <Head title={title} description={description} />
    </head>
    <body class="font-serif bg-slate-950 text-white">
        <slot />
    </body>
</html>
