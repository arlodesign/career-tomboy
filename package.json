{
    "name": "career-tomboy-website",
    "type": "module",
    "version": "1.0.0",
    "description": "Static marketing site for Career Tomboy, a Chicago cover band.",
    "homepage": "https://careertomboy.com/",
    "license": "MIT",
    "scripts": {
        "dev": "astro dev",
        "prebuild": "node scripts/generate-favicons.mjs",
        "build": "astro build",
        "preview": "astro preview",
        "prepare": "husky",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "typecheck": "astro check"
    },
    "lint-staged": {
        "*.{astro,ts,js,mjs,cjs,json,css,html}": "prettier --write",
        "*.{astro,ts,js,mjs}": "eslint --fix"
    },
    "dependencies": {
        "astro": "^6.0.4",
        "html-entities": "^2.6.0",
        "sharp": "^0.34.5"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.7",
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.1.18",
        "eslint": "^10.0.2",
        "eslint-plugin-astro": "^1.6.0",
        "favicons": "^7.2.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.1",
        "prettier": "^3.8.1",
        "prettier-plugin-astro": "^0.14.1",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    },
    "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
